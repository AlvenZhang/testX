# 技术验证环境变量配置
# 复制此文件为 .env 并修改为实际值

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=your_password
DB_NAME=testdb

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379

# Android设备配置
ANDROID_DEVICE_IP=192.168.1.100
ANDROID_DEVICE_PORT=5555

# Appium配置
APPIUM_PORT=4723

# iOS设备配置 (macOS only)
IOS_DEVICE_NAME=iPhone 15 Pro
IOS_VERSION=17.0
